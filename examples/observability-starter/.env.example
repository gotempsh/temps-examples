# =============================================================================
# Temps Observability Starter — environment variables
# =============================================================================
# When you deploy this template on Temps and attach a Postgres service, DATABASE_URL
# is injected for you. The analytics ingest path also works out of the box on
# Temps with no token. The OTEL_* and SENTRY_* values come from your project's
# Monitoring / Error Tracking settings.

# --- Database (auto-injected on Temps when a Postgres service is attached) ----
DATABASE_URL=postgres://user:password@localhost:5432/observability_starter

# --- Error tracking (Temps is Sentry wire-compatible) ------------------------
# Project → Error Tracking → DSN & Setup
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- Tracing & metrics (OpenTelemetry → Temps) -------------------------------
# Project → Monitoring → OTLP endpoint + token.
# On Temps these are injected automatically on deploy: OTEL_EXPORTER_OTLP_ENDPOINT
# is the OTLP base ({host}/api/otel) and the auth token rides in
# OTEL_EXPORTER_OTLP_HEADERS. Both traces ({base}/v1/traces) and metrics
# ({base}/v1/metrics) are exported with that same auth header.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_TOKEN=
OTEL_SERVICE_NAME=observability-starter
