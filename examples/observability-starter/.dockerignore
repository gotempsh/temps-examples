# Keep the build context small and the image clean. The Dockerfile installs
# dependencies fresh inside the image (bun install) and builds there, so the
# host's node_modules / .next must NOT be copied in (wrong arch + stale output).
node_modules
.next
.git
.gitignore

# Secrets / local env — never bake into the image.
.env
.env.*
.env*.local

# Tooling / noise that the runtime image doesn't need.
Dockerfile
.dockerignore
README.md
*.log
.DS_Store
npm-debug.log*
.vscode
.idea
