---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ProjectCard from "../components/ProjectCard.astro";
import astroLogo from "../assets/astro-logo.svg";

const projects = [
  {
    image: "/images/project-1.svg",
    title: "Analytics Dashboard",
    description:
      "Real-time analytics dashboard with interactive charts, KPI tracking, and data export. Built with a focus on performance and accessibility.",
    tags: ["React", "TypeScript", "D3.js", "PostgreSQL"],
    link: "#",
  },
  {
    image: "/images/project-2.svg",
    title: "FinTrack Mobile",
    description:
      "Personal finance tracking app with budget management, transaction categorization, and spending insights. Cross-platform mobile experience.",
    tags: ["React Native", "Expo", "SQLite", "Plaid API"],
    link: "#",
  },
  {
    image: "/images/project-3.svg",
    title: "REST API Toolkit",
    description:
      "High-performance REST API framework with JWT authentication, rate limiting, and comprehensive test coverage. Built for developer ergonomics.",
    tags: ["Bun", "Hono", "Drizzle ORM", "Redis"],
    link: "#",
  },
  {
    image: "/images/project-4.svg",
    title: "SaaS Landing Page",
    description:
      "Conversion-optimized landing page with smooth animations, responsive design, and A/B testing infrastructure. Loads in under 1 second.",
    tags: ["Astro", "Tailwind CSS", "Framer Motion", "Vercel"],
    link: "#",
  },
];

const skills = [
  { name: "TypeScript", category: "language" },
  { name: "JavaScript", category: "language" },
  { name: "Rust", category: "language" },
  { name: "Python", category: "language" },
  { name: "React", category: "frontend" },
  { name: "Astro", category: "frontend" },
  { name: "Svelte", category: "frontend" },
  { name: "Next.js", category: "frontend" },
  { name: "Tailwind CSS", category: "frontend" },
  { name: "Node.js", category: "backend" },
  { name: "Bun", category: "backend" },
  { name: "PostgreSQL", category: "backend" },
  { name: "Redis", category: "backend" },
  { name: "Docker", category: "devops" },
  { name: "AWS", category: "devops" },
  { name: "Git", category: "devops" },
  { name: "CI/CD", category: "devops" },
  { name: "Figma", category: "design" },
];

const categoryColors: Record<string, string> = {
  language: "bg-emerald-500/10 text-emerald-700 dark:text-emerald-400",
  frontend: "bg-teal-500/10 text-teal-700 dark:text-teal-400",
  backend: "bg-cyan-500/10 text-cyan-700 dark:text-cyan-400",
  devops: "bg-sky-500/10 text-sky-700 dark:text-sky-400",
  design: "bg-violet-500/10 text-violet-700 dark:text-violet-400",
};
---

<Layout title="Alex Chen — Fullstack Developer">
  <Header />

  <main>
    <!-- ── Hero ── -->
    <section class="relative overflow-hidden">
      <!-- Background decoration -->
      <div
        class="pointer-events-none absolute left-1/2 top-0 -translate-x-1/2 -translate-y-1/3 h-[700px] w-[700px] rounded-full bg-gradient-to-br from-emerald-500/15 via-teal-500/10 to-transparent blur-3xl"
      >
      </div>
      <div
        class="pointer-events-none absolute right-0 bottom-0 h-[400px] w-[400px] rounded-full bg-gradient-to-tl from-teal-500/10 via-cyan-500/5 to-transparent blur-3xl"
      >
      </div>

      <div
        class="relative mx-auto max-w-6xl px-4 pb-20 pt-24 sm:px-6 sm:pt-32 lg:pt-40"
      >
        <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
          <!-- Text -->
          <div class="flex flex-col items-start gap-6">
            <span
              class="animate-fade-in inline-flex items-center gap-1.5 rounded-full border border-primary/20 bg-primary/5 px-3 py-1 text-xs font-medium text-primary"
            >
              <span class="relative flex h-2 w-2">
                <span
                  class="absolute inline-flex h-full w-full animate-ping rounded-full bg-primary opacity-75"
                ></span>
                <span
                  class="relative inline-flex h-2 w-2 rounded-full bg-primary"
                ></span>
              </span>
              Available for freelance work
            </span>

            <h1
              class="animate-fade-in-up text-4xl font-extrabold tracking-tight sm:text-5xl lg:text-6xl"
            >
              Hi, I'm{" "}
              <span
                class="bg-gradient-to-r from-emerald-600 via-teal-500 to-cyan-500 bg-clip-text text-transparent"
              >
                Alex Chen
              </span>
            </h1>

            <p
              class="animate-fade-in-up delay-200 max-w-lg text-lg text-muted-foreground leading-relaxed"
            >
              A fullstack developer who crafts fast, accessible, and
              beautifully designed web experiences. I love turning complex
              problems into simple, elegant solutions.
            </p>

            <div class="animate-fade-in-up delay-300 flex flex-wrap gap-3">
              <a
                href="#projects"
                class="inline-flex items-center justify-center gap-2 rounded-lg bg-primary px-5 py-2.5 text-sm font-medium text-primary-foreground shadow-sm transition-colors hover:bg-primary/90"
              >
                View Projects
                <svg
                  class="size-4"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M5 12h14" />
                  <path d="m12 5 7 7-7 7" />
                </svg>
              </a>
              <a
                href="#contact"
                class="inline-flex items-center justify-center gap-2 rounded-lg border border-border bg-card px-5 py-2.5 text-sm font-medium text-card-foreground shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground"
              >
                Get in Touch
              </a>
            </div>

            <!-- Tech icons row -->
            <div
              class="animate-fade-in-up delay-400 flex items-center gap-4 pt-2"
            >
              <span class="text-xs text-muted-foreground">Built with</span>
              <div class="flex items-center gap-3">
                <img
                  src={astroLogo.src}
                  alt="Astro"
                  class="size-7"
                />
                <svg class="size-7 text-primary" viewBox="0 0 32 32" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                  <path d="M6 2h20l-2 28L16 32 8 30 6 2zm16.8 8H12.4l.4 4h9.6l-.8 10-5.6 2-5.6-2-.4-4h4l.2 2 1.8.6 1.8-.6.2-2.4H11.6L10.8 6h10.4l-.4 4z" opacity="0.5" />
                </svg>
              </div>
            </div>
          </div>

          <!-- Illustration -->
          <div
            class="animate-fade-in-up delay-300 flex items-center justify-center lg:justify-end"
          >
            <div class="relative">
              <div
                class="animate-pulse-glow absolute inset-0 rounded-full bg-gradient-to-br from-emerald-500/20 via-teal-500/10 to-cyan-400/10 blur-2xl"
              >
              </div>
              <img
                src="/images/profile.svg"
                alt="Developer illustration"
                class="animate-float relative z-10 w-full max-w-[360px]"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── About ── -->
    <section id="about" class="bg-muted/40 py-20 sm:py-28">
      <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
          <div class="animate-slide-in-left">
            <div
              class="relative aspect-square max-w-md overflow-hidden rounded-2xl border border-border bg-card p-6"
            >
              <!-- Abstract geometric composition -->
              <svg viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg" class="h-full w-full">
                <rect width="400" height="400" fill="transparent" />

                <!-- Grid pattern -->
                <line x1="0" y1="100" x2="400" y2="100" stroke="currentColor" stroke-opacity="0.05" />
                <line x1="0" y1="200" x2="400" y2="200" stroke="currentColor" stroke-opacity="0.05" />
                <line x1="0" y1="300" x2="400" y2="300" stroke="currentColor" stroke-opacity="0.05" />
                <line x1="100" y1="0" x2="100" y2="400" stroke="currentColor" stroke-opacity="0.05" />
                <line x1="200" y1="0" x2="200" y2="400" stroke="currentColor" stroke-opacity="0.05" />
                <line x1="300" y1="0" x2="300" y2="400" stroke="currentColor" stroke-opacity="0.05" />

                <!-- Large emerald hexagon -->
                <path d="M200 40L320 110V250L200 320L80 250V110L200 40Z" fill="#059669" fill-opacity="0.08" stroke="#059669" stroke-opacity="0.2" stroke-width="1.5" />

                <!-- Inner hexagon -->
                <path d="M200 100L270 140V220L200 260L130 220V140L200 100Z" fill="#0d9488" fill-opacity="0.1" stroke="#0d9488" stroke-opacity="0.25" stroke-width="1" />

                <!-- Code bracket shapes -->
                <text x="155" y="195" font-family="monospace" font-size="60" fill="#059669" fill-opacity="0.15">&lt;/&gt;</text>

                <!-- Floating dots -->
                <circle cx="80" cy="60" r="6" fill="#059669" fill-opacity="0.2" />
                <circle cx="320" cy="60" r="4" fill="#0d9488" fill-opacity="0.15" />
                <circle cx="60" cy="340" r="5" fill="#06b6d4" fill-opacity="0.15" />
                <circle cx="340" cy="340" r="7" fill="#059669" fill-opacity="0.12" />
                <circle cx="200" cy="360" r="3" fill="#0d9488" fill-opacity="0.2" />

                <!-- Connecting lines -->
                <line x1="80" y1="60" x2="200" y2="100" stroke="#059669" stroke-opacity="0.1" stroke-width="1" stroke-dasharray="4 4" />
                <line x1="320" y1="60" x2="270" y2="140" stroke="#0d9488" stroke-opacity="0.1" stroke-width="1" stroke-dasharray="4 4" />

                <!-- Small decorative rectangles -->
                <rect x="30" y="180" width="30" height="30" rx="6" fill="#059669" fill-opacity="0.08" transform="rotate(15 45 195)" />
                <rect x="340" y="200" width="25" height="25" rx="5" fill="#0d9488" fill-opacity="0.08" transform="rotate(-10 352 212)" />
              </svg>
            </div>
          </div>

          <div class="animate-slide-in-right">
            <h2
              class="mb-6 text-3xl font-bold tracking-tight sm:text-4xl"
            >
              About Me
            </h2>
            <div class="space-y-4 text-muted-foreground leading-relaxed">
              <p>
                I'm a fullstack developer with 6+ years of experience building
                web applications that are fast, accessible, and a joy to use.
                My journey started with vanilla JavaScript and PHP, and has
                evolved into working with modern tools like TypeScript, React,
                Astro, and Bun.
              </p>
              <p>
                I care deeply about performance, clean code, and user
                experience. Whether it's architecting a backend API, designing
                a component system, or optimizing a build pipeline, I approach
                every challenge with the same attention to detail.
              </p>
              <p>
                When I'm not coding, you'll find me exploring hiking trails,
                experimenting with espresso recipes, or contributing to
                open-source projects.
              </p>
            </div>
            <div class="mt-8 flex flex-wrap gap-4">
              <div class="rounded-lg border border-border bg-card px-4 py-3">
                <p class="text-2xl font-bold text-primary">6+</p>
                <p class="text-xs text-muted-foreground">Years Experience</p>
              </div>
              <div class="rounded-lg border border-border bg-card px-4 py-3">
                <p class="text-2xl font-bold text-primary">40+</p>
                <p class="text-xs text-muted-foreground">Projects Shipped</p>
              </div>
              <div class="rounded-lg border border-border bg-card px-4 py-3">
                <p class="text-2xl font-bold text-primary">12</p>
                <p class="text-xs text-muted-foreground">Open Source Libs</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Projects ── -->
    <section id="projects" class="py-20 sm:py-28">
      <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <div class="mx-auto mb-14 max-w-2xl text-center">
          <h2
            class="animate-fade-in text-3xl font-bold tracking-tight sm:text-4xl"
          >
            Featured Projects
          </h2>
          <p class="animate-fade-in delay-100 mt-4 text-muted-foreground">
            A selection of recent work spanning dashboards, mobile apps, APIs,
            and marketing sites.
          </p>
        </div>

        <div class="grid gap-6 sm:grid-cols-2">
          {
            projects.map((project, i) => (
              <div class={`animate-fade-in-up delay-${(i + 1) * 100}`}>
                <ProjectCard {...project} />
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ── Skills ── -->
    <section id="skills" class="bg-muted/40 py-20 sm:py-28">
      <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <div class="mx-auto mb-14 max-w-2xl text-center">
          <h2
            class="animate-fade-in text-3xl font-bold tracking-tight sm:text-4xl"
          >
            Skills & Technologies
          </h2>
          <p class="animate-fade-in delay-100 mt-4 text-muted-foreground">
            Tools and technologies I use to bring ideas to life.
          </p>
        </div>

        <div
          class="animate-fade-in-up delay-200 flex flex-wrap items-center justify-center gap-2.5"
        >
          {
            skills.map((skill) => (
              <span
                class={`inline-flex items-center rounded-full px-4 py-2 text-sm font-medium transition-transform hover:scale-105 ${categoryColors[skill.category]}`}
              >
                {skill.name}
              </span>
            ))
          }
        </div>

        <!-- Legend -->
        <div
          class="animate-fade-in delay-300 mt-8 flex flex-wrap items-center justify-center gap-4 text-xs text-muted-foreground"
        >
          <span class="flex items-center gap-1.5">
            <span class="size-2.5 rounded-full bg-emerald-500/30"></span>
            Languages
          </span>
          <span class="flex items-center gap-1.5">
            <span class="size-2.5 rounded-full bg-teal-500/30"></span>
            Frontend
          </span>
          <span class="flex items-center gap-1.5">
            <span class="size-2.5 rounded-full bg-cyan-500/30"></span>
            Backend
          </span>
          <span class="flex items-center gap-1.5">
            <span class="size-2.5 rounded-full bg-sky-500/30"></span>
            DevOps
          </span>
          <span class="flex items-center gap-1.5">
            <span class="size-2.5 rounded-full bg-violet-500/30"></span>
            Design
          </span>
        </div>
      </div>
    </section>

    <!-- ── Contact ── -->
    <section id="contact" class="py-20 sm:py-28">
      <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <div class="mx-auto max-w-2xl text-center">
          <h2
            class="animate-fade-in text-3xl font-bold tracking-tight sm:text-4xl"
          >
            Let's Work Together
          </h2>
          <p
            class="animate-fade-in delay-100 mt-4 text-muted-foreground leading-relaxed"
          >
            Have a project in mind or want to collaborate? I'd love to hear
            from you. Drop me a line and let's build something great.
          </p>

          <div
            class="animate-fade-in-up delay-200 mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center"
          >
            <a
              href="mailto:alex@example.com"
              class="inline-flex items-center justify-center gap-2 rounded-lg bg-primary px-6 py-3 text-sm font-medium text-primary-foreground shadow-sm transition-colors hover:bg-primary/90"
            >
              <svg
                class="size-4"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect width="20" height="16" x="2" y="4" rx="2" />
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
              </svg>
              alex@example.com
            </a>

            <div class="flex items-center gap-2">
              <a
                href="https://github.com"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center size-10 rounded-lg border border-border bg-card text-muted-foreground transition-colors hover:bg-accent hover:text-accent-foreground"
                aria-label="GitHub"
              >
                <svg
                  class="size-4"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                  <path d="M9 18c-4.51 2-5-2-7-2" />
                </svg>
              </a>
              <a
                href="https://linkedin.com"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center size-10 rounded-lg border border-border bg-card text-muted-foreground transition-colors hover:bg-accent hover:text-accent-foreground"
                aria-label="LinkedIn"
              >
                <svg
                  class="size-4"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                  <rect width="4" height="12" x="2" y="9" />
                  <circle cx="4" cy="4" r="2" />
                </svg>
              </a>
              <a
                href="https://twitter.com"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center size-10 rounded-lg border border-border bg-card text-muted-foreground transition-colors hover:bg-accent hover:text-accent-foreground"
                aria-label="Twitter"
              >
                <svg
                  class="size-4"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
